{"version":"0.3.0","body":"/*\nMicrosoftドキュメントのサンプルから作成\nhttps://learn.microsoft.com/ja-jp/office/dev/scripts/resources/samples/convert-csv\nhttps://learn.microsoft.com/ja-jp/office/dev/scripts/resources/samples/write-large-dataset#power-automate-flow-read-and-write-data-in-a-loop\n*/\n\n/**\n * CSVデータを指定された行数分読み取り、Excelに書き込む\n * @param workbook ExcelScript.Workbook\n * @param csv 読み込むCSVデータ（文字列）\n * @param startRow 読み取り開始行\n * @param batchSize 読み取る行数\n * @param sheetName 書き込み先シート名\n * @returns バッチサイズより少ないデータを書き込んだ場合はtrue\n */\nfunction main(\n  workbook: ExcelScript.Workbook,\n  csv: string,\n  startRow: number,\n  batchSize: number,\n  sheetName: string\n): boolean {\n  // 計算モード制御用\n  const application = workbook.getApplication();\n  application.setCalculationMode(ExcelScript.CalculationMode.manual);\n\n  // 現在の計算モードを取得して出力（デバッグ用）\n  let currentMode = application.getCalculationMode();\n  console.log(`現在の計算モード: ${currentMode}`);\n\n  // ---CSVデータの読み取り ---\n  // Windowsの\\r文字をすべて削除\n  csv = csv.replace(/\\r/g, \"\");\n\n  // 各行を分割\n  let rows = csv.split(\"\\n\");\n  let lastRowIndex = rows.length;\n\n  // startRowが最終行より大きければ終了\n  if (startRow >= lastRowIndex) {\n    console.log(\"startRowが最終行より大きいため、処理を終了します。\");\n    application.setCalculationMode(ExcelScript.CalculationMode.automatic);\n    return true;\n  }\n\n  // 読み取る行数を計算\n  let endRow = Math.min(startRow + batchSize, lastRowIndex);\n  let selectedRows = rows.slice(startRow, endRow);\n\n  // CSV解析用正規表現\n  const csvMatchRegex = /(?:,|\\n|^)(\"(?:(?:\"\")*[^\"]*)*\"|[^\",\\n]*|(?:\\n|$))/g;\n  let data: string[][] = [];\n\n  selectedRows.forEach((value) => {\n    if (value.length > 0) {\n      let selectedRow = value.match(csvMatchRegex);\n\n      // 行の先頭に空白がある場合\n      if (selectedRow[0].charAt(0) === ',') {\n        selectedRow.unshift(\"\");\n      }\n\n      // 先頭のカンマと周囲の引用符を削除\n      selectedRow.forEach((cell, index) => {\n        cell = cell.indexOf(\",\") === 0 ? cell.substring(1) : cell;\n        selectedRow[index] = cell.indexOf(\"\\\"\") === 0 && cell.lastIndexOf(\"\\\"\") === cell.length - 1\n          ? cell.substring(1, cell.length - 1)\n          : cell;\n      });\n\n      data.push(selectedRow);\n    }\n  });\n\n  // --- Excelへの書き込み ---\n  // シートがなければ作成し、取得する\n  let sheet = workbook.getWorksheet(sheetName);\n  if (!sheet) {\n    sheet = workbook.addWorksheet(sheetName);\n  } else if (startRow === 0) {\n    // startRowが0の時のみ内容をすべて削除\n    let usedRange = sheet.getUsedRange();\n    if (usedRange) {\n      usedRange.clear(ExcelScript.ClearApplyTo.contents);\n    }\n  }\n\n  // データの行数と列数\n  if (data && data.length > 0) {\n    let numRows = data.length;\n    let numCols = data[0].length;\n\n    // 先頭が0から始まる値がカットされるのを防ぐ\n    let formattedData = data.map(row => row.map(cell => {\n      if (cell.startsWith(\"000\")) {\n        return `'${cell}`;\n      }\n      return cell;\n    }));\n\n    // データをchunkSizeに分割して書き込み\n    // const chunkSize = 10;\n    // for (let i = 0; i < formattedData.length; i += chunkSize) {\n    //     let chunk = formattedData.slice(i, Math.min(i + chunkSize, formattedData.length));\n    //     let chunkRows = chunk.length;\n    //     let range = sheet.getRangeByIndexes(startRow + i, 0, chunkRows, numCols);\n    //     range.setValues(chunk);\n    // }\n\n    // 一括書き込み\n    let range = sheet.getRangeByIndexes(startRow, 0, numRows, numCols);\n    range.setValues(formattedData);\n  }\n\n  // 手動で再計算\n  application.calculate(ExcelScript.CalculationType.fullRebuild);\n\n  // 計算モードを自動に戻す\n  application.setCalculationMode(ExcelScript.CalculationMode.automatic);\n\n  // 切り替え後の計算モードを取得して出力\n  let switchedMode = application.getCalculationMode();\n  console.log(`切り替え後の計算モード: ${switchedMode}`);\n\n  // バッチサイズより少ないデータを書き込んだ場合、フローの終了を知らせる\n  return batchSize > data.length;\n}","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[{\"name\":\"csv\",\"index\":0},{\"name\":\"startRow\",\"index\":1},{\"name\":\"batchSize\",\"index\":2},{\"name\":\"sheetName\",\"index\":3}],\"parameterSchema\":{\"type\":\"object\",\"required\":[\"csv\",\"startRow\",\"batchSize\",\"sheetName\"],\"properties\":{\"csv\":{\"type\":\"string\"},\"startRow\":{\"type\":\"number\"},\"batchSize\":{\"type\":\"number\"},\"sheetName\":{\"type\":\"string\"}}},\"returnSchema\":{\"type\":\"object\",\"properties\":{\"result\":{\"type\":\"boolean\"}}},\"signature\":{\"comment\":\"CSVデータを指定された行数分読み取り、Excelに書き込む\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"ExcelScript.Workbook\"},{\"name\":\"csv\",\"comment\":\"読み込むCSVデータ（文字列）\"},{\"name\":\"startRow\",\"comment\":\"読み取り開始行\"},{\"name\":\"batchSize\",\"comment\":\"読み取る行数\"},{\"name\":\"sheetName\",\"comment\":\"書き込み先シート名\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}